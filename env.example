# Copy these into Railway → your service → Variables (do NOT commit a real .env file)

# Deriv API credentials
DERIV_APP_ID=1089
DERIV_API_TOKEN=your_deriv_api_token_here
DERIV_ACCOUNT_ID=your_deriv_account_id_here
DERIV_ACCOUNT_TYPE=demo          # demo | real

# Supabase (trade logging / persistence) — optional but recommended
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_supabase_service_key_here

# Logging
VERBOSE_LOGS=false               # true for verbose per-cycle gate/signal logs
